# Matomo — copier vers .env.matomo sur le VPS (chmod 600)
MATOMO_DOMAIN=analytics.wise-eat.com
MATOMO_ROOT_URL=https://analytics.wise-eat.com/
MATOMO_HTTP_PORT=8089
MATOMO_IMAGE_TAG=5.2.2-apache

# MariaDB (conteneur matomo-db, non exposé hors Docker)
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=
MATOMO_DB_ROOT_PASSWORD=

# Volume données (5 Go loop ext4 par défaut sur le VPS)
MATOMO_DATA_DIR=/var/lib/wise-eat/matomo
MATOMO_STORAGE_GB=5

# RAM + swap
MATOMO_MEM_LIMIT=512m
MATOMO_MEMSWAP_LIMIT=768m
MATOMO_PHP_MEMORY_LIMIT=512M
MATOMO_DB_MEM_LIMIT=256m
MATOMO_DB_MEMSWAP_LIMIT=384m

# Optionnel : bloc dédié au lieu du loop (ex. MATOMO_DATA_DEVICE=/dev/sdb1)
# MATOMO_DATA_DEVICE=
