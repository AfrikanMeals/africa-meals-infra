# Copié vers .env.emqx par install-emqx.sh (secrets générés automatiquement)

EMQX_CLUSTER_B_ENABLED=true
EMQX_ERLANG_COOKIE=CHANGE_ME
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME
MQTT_BROKER_PASSWORD=CHANGE_ME
MQTT_ADMIN_PASSWORD=CHANGE_ME

# Primary (localhost VPS)
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083

# Cluster static seeds (généré par install-emqx.sh)
EMQX_CLUSTER_STATIC_SEEDS=[emqx@wise-eat-emqx-1,emqx@wise-eat-emqx-2,emqx@wise-eat-emqx-3]

# Public TLS (nginx → primary)
EMQX_BROKER_DOMAIN=broker.wise-eat.com
EMQX_MQTTS_PORT=8883
EMQX_WSS_PORT=8884

# Dashboard public (nginx → primary :18083)
EMQX_WORKER_DOMAIN=worker.wise-eat.com
EMQX_WORKER_BASIC_AUTH_PASSWORD=CHANGE_ME

# RAM + swap par nœud (256 Mo + 128 Mo swap)
EMQX_MEM_LIMIT=256m
EMQX_MEMSWAP_LIMIT=384m
