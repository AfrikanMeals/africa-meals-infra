# Neo4j — copier vers .env.neo4j sur le VPS (chmod 600)
# Install : sudo ./install.sh neo4j

NEO4J_IMAGE_TAG=5.26-community

# Auth (format NEO4J_AUTH = user/password)
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Ports locaux (loopback + gateway k3s)
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Volume données (5 Go loop ext4 par défaut sur le VPS)
NEO4J_DATA_DIR=/var/lib/wise-eat/neo4j
NEO4J_STORAGE_GB=5

# RAM conteneur (1 Go) + heap / pagecache Neo4j
NEO4J_MEM_LIMIT=1g
NEO4J_MEMSWAP_LIMIT=1280m
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=128m

# Optionnel : bloc dédié au lieu du loop (ex. NEO4J_DATA_DEVICE=/dev/sdb1)
# NEO4J_DATA_DEVICE=

# Plugins (JSON array) — vide = aucun
# NEO4J_PLUGINS=["apoc"]

# Admin public Neo4j Browser (nginx → db-graph.wise-eat.com)
# DbGate ne supporte pas Neo4j — on expose le Browser natif + Bolt TLS :7688
NEO4J_ADMIN_DOMAIN=db-graph.wise-eat.com
NEO4J_ADMIN_BASIC_AUTH_USER=neo4j-admin
NEO4J_ADMIN_BASIC_AUTH_PASSWORD=
# Port public Bolt TLS (nginx stream → 127.0.0.1:7687) — DNS only Cloudflare
NEO4J_BOLT_TLS_PORT=7688
# Advertised pour le Browser public (install-neo4j-admin les force)
# NEO4J_HTTP_ADVERTISED=db-graph.wise-eat.com:443
# NEO4J_BOLT_ADVERTISED=db-graph.wise-eat.com:7688
