# HTTP — Ollama gateway (ai.wise-eat.com) — ACME + proxy vers Ollama local
# Déployé par : scripts/install-ollama-gateway.sh

server {
    listen 80;
    listen [::]:80;
    server_name ${OLLAMA_GATEWAY_DOMAIN};

    location /.well-known/acme-challenge/ {
        root ${CERTBOT_WEBROOT};
    }

    location / {
        auth_basic "Ollama API";
        auth_basic_user_file ${OLLAMA_GATEWAY_HTASSWD_FILE};

        proxy_pass http://${OLLAMA_BACKEND_HOST}:${OLLAMA_BACKEND_PORT};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600;
        proxy_send_timeout 600;
        client_max_body_size 32m;
    }
}
