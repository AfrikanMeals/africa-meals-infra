# Memcached — copier vers .env.memcached sur le VPS (chmod 600)
MEMCACHED_PORT=11211
MEMCACHED_MEMORY_MB=128
MEMCACHED_MAX_ITEM_MB=2
MEMCACHED_MAX_CONNECTIONS=1024

# Cluster B (2e pool indépendant — sharding client si les deux listés)
MEMCACHED_CLUSTER_B_ENABLED=true
MEMCACHED_B_PORT=11213
MEMCACHED_B_MEMORY_MB=128
