# Modèle aligné sur africa-meals-ws/.env.prod
# Génération : infra/k8s/scripts/create-ws-secret.sh africa-meals-ws/.env.prod
#
# Les URLs utilisent host.k3s.internal (= 127.0.0.1 côté VPS) avec mots de passe réels.

JWT_SECRET=identique-a-l-api
INTERNAL_NOTIFY_SECRET=identique-a-l-api

# MongoDB Stunnel local — host pod + SNI db.wise-eat.com (ConfigMap MONGODB_TLS_SERVERNAME)
MONGODB_URI=mongodb://wise-eat-app:PASSWORD@host.k3s.internal:27018/wise_eat_db?authSource=admin&tls=true&directConnection=true
# Ou Atlas :
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/african_meals_db

REDIS_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6381
REDIS_REPLICA_1_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6383
REDIS_REPLICA_2_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6384

BULLMQ_REDIS_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6382
BULLMQ_REDIS_REPLICA_1_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6385
BULLMQ_REDIS_REPLICA_2_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6386

MQTT_BROKER_PASSWORD=mot-de-passe-emqx

# Optionnel
# SUPPORT_STAFF_USER_ID=
# NEXT_PUBLIC_FCM_VAPID_KEY=
