# Modèle aligné sur africa-meals-ws/.env.prod
# Génération : infra/k8s/scripts/create-ws-secret.sh africa-meals-ws/.env.prod
#
# Les URLs utilisent host.k3s.internal (= 127.0.0.1 côté VPS) avec mots de passe réels.

JWT_SECRET=identique-a-l-api
INTERNAL_NOTIFY_SECRET=identique-a-l-api

# MongoDB rs0 local — pods k8s : Stunnel TLS :27018 (pas 27017/27027/27028)
MONGODB_URI=mongodb://wise-eat-app:PASSWORD@host.k3s.internal:27018/wise_eat_db?authSource=admin&tls=true&directConnection=true&retryWrites=true&w=majority

# PM2 / processus sur le VPS (ports Mongo locaux)
# MONGODB_URI=mongodb://wise-eat-app:PASSWORD@host.k3s.internal:27017,host.k3s.internal:27027,host.k3s.internal:27028/wise_eat_db?authSource=admin&replicaSet=rs0&retryWrites=true&w=majority
# Ou Atlas :
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/african_meals_db

REDIS_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6381
REDIS_REPLICA_1_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6383
REDIS_REPLICA_2_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6384

BULLMQ_REDIS_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6382
BULLMQ_REDIS_REPLICA_1_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6385
BULLMQ_REDIS_REPLICA_2_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6386

MQTT_BROKER_PASSWORD=mot-de-passe-emqx

# Dry run HTTP (load test prod sans écriture) — voir ConfigMap DRY_RUN_* ou Secret
# DRY_RUN_SECRET=

# App Check (Firebase Admin) — préférer le volume k8s (accounts.json) :
#   infra/k8s/scripts/create-api-firebase-secret.sh /opt/wise-eat-api/accounts.json
#   → monte /run/secrets/firebase/accounts.json sur API + WS
# Alternative inline (évite si possible — JSON volumineux dans le Secret env) :
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optionnel
# SUPPORT_STAFF_USER_ID=
# NEXT_PUBLIC_FCM_VAPID_KEY=
