# Modèle aligné sur africa-meals-ws/.env.prod
# Génération : infra/k8s/scripts/create-ws-secret.sh africa-meals-ws/.env.prod
#
# create-ws-secret.sh réécrit vers host.k3s.internal + ports plaintext locaux
# (Mongo 27017/27027/27028, Redis 6379/6380, sans TLS Stunnel).

JWT_SECRET=identique-a-l-api
INTERNAL_NOTIFY_SECRET=identique-a-l-api

# MongoDB rs0 local — pods k8s via host.k3s.internal (plaintext, pas Stunnel :27018)
MONGODB_URI=mongodb://wise-eat-app:PASSWORD@host.k3s.internal:27017,host.k3s.internal:27027,host.k3s.internal:27028/wise_eat_db?authSource=admin&replicaSet=rs0&retryWrites=true&w=majority

# Accès distant / admin uniquement (Stunnel) — ne pas utiliser depuis les pods k8s :
# MONGODB_URI=mongodb://wise-eat-app:PASSWORD@db.wise-eat.com:27018/wise_eat_db?authSource=admin&tls=true&directConnection=true

# Ou Atlas :
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/african_meals_db

# .env.prod peut encore avoir rediss://…:6381 — create-ws-secret.sh mappe vers redis://…:6379
REDIS_URL=redis://wise-eat-cache:PASSWORD@host.k3s.internal:6379
REDIS_REPLICA_1_URL=redis://wise-eat-cache:PASSWORD@host.k3s.internal:6371
REDIS_REPLICA_2_URL=redis://wise-eat-cache:PASSWORD@host.k3s.internal:6372

BULLMQ_REDIS_URL=redis://wise-eat-bull:PASSWORD@host.k3s.internal:6380
BULLMQ_REDIS_REPLICA_1_URL=redis://wise-eat-bull:PASSWORD@host.k3s.internal:6390
BULLMQ_REDIS_REPLICA_2_URL=redis://wise-eat-bull:PASSWORD@host.k3s.internal:6391

MQTT_BROKER_PASSWORD=mot-de-passe-emqx

# Dry run HTTP (load test prod sans écriture) — voir ConfigMap DRY_RUN_* ou Secret
# DRY_RUN_SECRET=

# App Check (Firebase Admin) — préférer le volume k8s (accounts.json) :
#   infra/k8s/scripts/create-api-firebase-secret.sh /opt/wise-eat-api/accounts.json
#   → monte /run/secrets/firebase/accounts.json sur API + WS
# Alternative inline (évite si possible — JSON volumineux dans le Secret env) :
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optionnel
# SUPPORT_STAFF_USER_ID=
# NEXT_PUBLIC_FCM_VAPID_KEY=
