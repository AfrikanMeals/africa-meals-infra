# Modèle — Secret complet depuis .env.prod (VPS /opt/wise-eat-api)
# Génération : infra/k8s/scripts/create-api-secret.sh africa-meals-api/.env.prod
#
# Le ConfigMap k8s écrase les hosts publics (host.k3s.internal, pools, URLs internes).
# Ce fichier liste les clés sensibles typiques — le script importe tout le .env.

JWT_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_NOTIFY_SECRET=

MONGODB_URI=mongodb://wise-eat-app:PASSWORD@host.k3s.internal:27018/wise_eat_db?authSource=admin&tls=true&directConnection=true

REDIS_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6381
REDIS_REPLICA_1_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6383
REDIS_REPLICA_2_URL=rediss://wise-eat-cache:PASSWORD@host.k3s.internal:6384

BULLMQ_REDIS_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6382
BULLMQ_REDIS_REPLICA_1_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6385
BULLMQ_REDIS_REPLICA_2_URL=rediss://wise-eat-bull:PASSWORD@host.k3s.internal:6386

MQTT_BROKER_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRETS=

SMTP_APP_PASSWORD=
AD_SMTP_APP_PASSWORD=

# Dry run HTTP (load test prod sans écriture) — DRY_RUN_ENABLED=true dans ConfigMap
DRY_RUN_SECRET=

# Fichier séparé (optionnel) :
#   create-api-firebase-secret.sh /opt/wise-eat-api/accounts.json
