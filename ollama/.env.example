# Copier vers /opt/wise-eat/ollama/.env.ollama (chmod 600)

OLLAMA_PORT=11434
OLLAMA_DATA_DIR=/var/lib/wise-eat/ollama

# Réglages VPS Wise Eat (2 vCPU / 8 Go RAM, CPU-only, stack partagé Mongo/EMQX/Redis…)
OLLAMA_MEM_LIMIT=3g
OLLAMA_MEMSWAP_LIMIT=4g
OLLAMA_CPU_LIMIT=1.5
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=8
OLLAMA_KEEP_ALIVE=2m
OLLAMA_CONTEXT_LENGTH=1024

# Modèles téléchargés au premier install (peut prendre plusieurs minutes)
OLLAMA_MODELS=nomic-embed-text,llama3.2:3b

# Gateway public (nginx)
OLLAMA_GATEWAY_DOMAIN=ai.wise-eat.com
OLLAMA_GATEWAY_BASIC_AUTH_USER=ollama
OLLAMA_GATEWAY_BASIC_AUTH_PASSWORD=
