# Secrets Redis — copier vers .env.redis sur le VPS (chmod 600)
CACHE_REDIS_PASSWORD=
BULL_REDIS_PASSWORD=

# Cluster B : réplicas lecture (même VPS, ports distincts)
# Bascule apps : REDIS_PORT=6371 / BULLMQ_REDIS_PORT=6390 (manuel)
REDIS_CLUSTER_B_ENABLED=true
CACHE_REDIS_REPLICA_PORT=6371
BULL_REDIS_REPLICA_PORT=6390
