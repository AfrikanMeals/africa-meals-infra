# Secrets Redis — copier vers .env.redis sur le VPS (chmod 600)
CACHE_REDIS_PASSWORD=
BULL_REDIS_PASSWORD=

# 1 primary + 2 réplicas (profile cluster-b)
REDIS_CLUSTER_B_ENABLED=true
CACHE_REDIS_REPLICA_1_PORT=6371
CACHE_REDIS_REPLICA_2_PORT=6372
BULL_REDIS_REPLICA_1_PORT=6390
BULL_REDIS_REPLICA_2_PORT=6391

# RAM + swap (memswap_limit = maxmemory Redis + marge process + swap)
REDIS_CACHE_MEM_LIMIT=896m
REDIS_CACHE_MEMSWAP_LIMIT=1152m
REDIS_BULL_MEM_LIMIT=640m
REDIS_BULL_MEMSWAP_LIMIT=768m
