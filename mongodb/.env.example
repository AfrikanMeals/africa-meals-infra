# Copier vers /opt/wise-eat/mongodb/.env.mongodb (chmod 600)
# Généré automatiquement par : sudo ./install.sh mongodb

MONGO_ROOT_USER=wise-eat-mongo
MONGO_ROOT_PASSWORD=
MONGO_APP_USER=wise-eat-app
MONGO_APP_PASSWORD=
MONGO_APP_DATABASE=wise_eat_db

MONGO_REPLICA_SET=rs0
MONGO_PRIMARY_PORT=27017
MONGO_REPLICA_1_PORT=27027
MONGO_REPLICA_2_PORT=27028
MONGO_DBGATE_PORT=8081
MONGO_DBGATE_MEM_LIMIT=512m
MONGO_DBGATE_DATA=./data-dbgate

# Ressources (512 Mo RAM + swap par conteneur — 1,5 Go total rs0)
MONGO_MEM_LIMIT=512m
MONGO_MEMSWAP_LIMIT=1g
# Minimum MongoDB 8 (ne pas descendre sous 0.25)
MONGO_WIREDTIGER_CACHE_GB=0.25
MONGO_DBGATE_MEM_LIMIT=512m
MONGO_DBGATE_MEMSWAP_LIMIT=768m

# Stockage 5 Go (volume loop ext4 sur VPS)
MONGO_DATA_DIR=/var/lib/wise-eat/mongodb
MONGO_STORAGE_GB=5
MONGO_DATA_1=/var/lib/wise-eat/mongodb/data-mongo-1
MONGO_DATA_2=/var/lib/wise-eat/mongodb/data-mongo-2
MONGO_DATA_3=/var/lib/wise-eat/mongodb/data-mongo-3

# TLS public (Stunnel)
MONGO_TLS_DOMAIN=db.wise-eat.com
MONGO_TLS_PORT=27018

# Console admin publique (nginx)
MONGO_ADMIN_DOMAIN=data.wise-eat.com
MONGO_ADMIN_BASIC_AUTH_USER=mongo-admin
MONGO_ADMIN_BASIC_AUTH_PASSWORD=

# Sauvegarde locale
MONGO_BACKUP_ENABLED=1
MONGO_BACKUP_DIR=/var/backups/wise-eat-mongodb
MONGO_BACKUP_RETENTION_DAYS=30
MONGO_BACKUP_CRON="30 3 * * *"
MONGO_BACKUP_SNAPSHOT_WEEKDAY=7

# Upload cloud hebdomadaire — credentials depuis /opt/wise-eat-api/.env.prod
# (GCS_BUCKET, AM_FIREBASE_STORAGE_BUCKET, AWS_S3_BUCKET, AWS_* , GOOGLE_APPLICATION_CREDENTIALS / accounts.json)
MONGO_CLOUD_BACKUP_ENABLED=1
MONGO_CLOUD_API_ENV=/opt/wise-eat-api/.env.prod
MONGO_CLOUD_BACKUP_CRON="0 4 * * 0"
MONGO_CLOUD_BACKUP_WEEKDAY=7
MONGO_CLOUD_BACKUP_PREFIX=Backup_DB_
MONGO_CLOUD_OBJECT_PREFIX=mongodb
MONGO_CLOUD_AUTO_ENABLE_DESTINATIONS=1

# Overrides optionnels (laisser vide pour auto depuis .env.prod)
# MONGO_CLOUD_GCS_URI=gs://mon-bucket/mongodb
# MONGO_CLOUD_FIREBASE_URI=gs://wise-eat-ca.firebasestorage.app/mongodb
# MONGO_CLOUD_AWS_URI=s3://wise-eat/mongodb
# MONGO_CLOUD_GCS_ENABLED=0
# MONGO_CLOUD_FIREBASE_ENABLED=0
# MONGO_CLOUD_AWS_ENABLED=0
