# Copier vers /opt/wise-eat/mongodb/.env.mongodb (chmod 600)
# Généré automatiquement par : sudo ./install.sh mongodb

MONGO_ROOT_USER=wise-eat-mongo
MONGO_ROOT_PASSWORD=
MONGO_APP_USER=wise-eat-app
MONGO_APP_PASSWORD=
MONGO_APP_DATABASE=african_meals_db

MONGO_REPLICA_SET=rs0
MONGO_PRIMARY_PORT=27017
MONGO_REPLICA_1_PORT=27027
MONGO_REPLICA_2_PORT=27028
MONGO_DBGATE_PORT=8081
MONGO_DBGATE_MEM_LIMIT=512m
MONGO_DBGATE_DATA=./data-dbgate

# Ressources (1 Go RAM + swap par conteneur)
MONGO_MEM_LIMIT=1g
MONGO_MEMSWAP_LIMIT=2g
MONGO_WIREDTIGER_CACHE_GB=0.25

# Stockage 5 Go (volume loop ext4 sur VPS)
MONGO_DATA_DIR=/var/lib/wise-eat/mongodb
MONGO_STORAGE_GB=5
MONGO_DATA_1=/var/lib/wise-eat/mongodb/data-mongo-1
MONGO_DATA_2=/var/lib/wise-eat/mongodb/data-mongo-2
MONGO_DATA_3=/var/lib/wise-eat/mongodb/data-mongo-3

# TLS public (Stunnel)
MONGO_TLS_DOMAIN=db.wise-eat.com
MONGO_TLS_PORT=27018

# Console admin publique (nginx)
MONGO_ADMIN_DOMAIN=data.wise-eat.com
MONGO_ADMIN_BASIC_AUTH_USER=mongo-admin
MONGO_ADMIN_BASIC_AUTH_PASSWORD=

# Sauvegarde
MONGO_BACKUP_ENABLED=1
MONGO_BACKUP_DIR=/var/backups/wise-eat-mongodb
MONGO_BACKUP_RETENTION_DAYS=30
MONGO_BACKUP_CRON="30 3 * * *"
MONGO_BACKUP_SNAPSHOT_WEEKDAY=7
