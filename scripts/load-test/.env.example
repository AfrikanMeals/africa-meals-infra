# Copier vers scripts/load-test/.env (chmod 600) — ne jamais committer

LOAD_TEST_API_BASE=https://api.wise-eat.com/api
LOAD_TEST_WS_BASE=https://ws.wise-eat.com

LOAD_TEST_EMAIL=
LOAD_TEST_PASSWORD=

# Optionnel : JWT déjà émis (évite /auth/login — utile si 2FA ou rate-limit login)
# LOAD_TEST_AUTH_TOKEN=

# Simulation utilisateurs concurrents
LOAD_TEST_VUS=10
LOAD_TEST_RAMP_UP=30s
LOAD_TEST_DURATION=1m
LOAD_TEST_RAMP_DOWN=15s
LOAD_TEST_THINK_TIME_SECONDS=1

# Nb fixe d’itérations (1 itération = 1 tour complet d’endpoints du script).
# Si défini (>0), remplace le mode durée (ramping-vus) par shared-iterations.
# LOAD_TEST_ITERATIONS=100
# LOAD_TEST_MAX_DURATION=30m

# api | ws | both
LOAD_TEST_TARGET=both

# Durée de maintien de chaque connexion STOMP (secondes)
LOAD_TEST_WS_HOLD_SECONDS=25

# Timeout HTTP par requête (k6 : 60s = 1 min)
LOAD_TEST_HTTP_TIMEOUT=60s
# Timeout connexion STOMP (millisecondes)
LOAD_TEST_WS_CONNECT_TIMEOUT_MS=60000

# Seuils k6 (relâcher si charge extrême)
# LOAD_TEST_HTTP_FAIL_THRESHOLD=0.10
# LOAD_TEST_HTTP_P95_MS=60000

# Dry run prod (aligné sur DRY_RUN_SECRET des pods API + WS)
LOAD_TEST_DRY_RUN=false
LOAD_TEST_DRY_RUN_SECRET=
