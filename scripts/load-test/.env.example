# Copier vers scripts/load-test/.env (chmod 600) — ne jamais committer

LOAD_TEST_API_BASE=https://api.wise-eat.com/api
LOAD_TEST_WS_BASE=https://ws.wise-eat.com

LOAD_TEST_EMAIL=
LOAD_TEST_PASSWORD=

# Optionnel : JWT déjà émis (évite /auth/login — utile si 2FA ou rate-limit login)
# LOAD_TEST_AUTH_TOKEN=

# Simulation utilisateurs concurrents
LOAD_TEST_VUS=10
LOAD_TEST_RAMP_UP=30s
LOAD_TEST_DURATION=1m
LOAD_TEST_RAMP_DOWN=15s
LOAD_TEST_THINK_TIME_SECONDS=1

# api | ws | both
LOAD_TEST_TARGET=both

# Durée de maintien de chaque connexion STOMP (secondes)
LOAD_TEST_WS_HOLD_SECONDS=25
