GRAFANA_ADMIN_PASSWORD=

# URL publique (reverse-proxy ou Cloudflare Tunnel) — requis pour les liens / cookies HTTPS
GRAFANA_ROOT_URL=https://console.wise-eat.com/

CACHE_REDIS_PASSWORD=DPsPBEeQdmECVNDOzFGeZIbyEDeKYClT
BULL_REDIS_PASSWORD=0hbukRD765aX3ZADGawsaTR3mVPuRw1Y

# Port Memcached sur l'hôte (wise-eat-memcached, défaut 11211)
