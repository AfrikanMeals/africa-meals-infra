# Copier vers /opt/wise-eat/monitoring/.env.monitoring (chmod 600)
# Les mots de passe Redis peuvent être repris de /opt/wise-eat/redis/.env.redis

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# URL publique (reverse-proxy ou Cloudflare Tunnel) — requis pour les liens / cookies HTTPS
GRAFANA_ROOT_URL=https://console.wise-eat.com/

# URL publique Prometheus (nginx basic auth sur logs.wise-eat.com)
PROMETHEUS_EXTERNAL_URL=https://logs.wise-eat.com/
PROMETHEUS_BASIC_AUTH_USER=prometheus
PROMETHEUS_BASIC_AUTH_PASSWORD=

CACHE_REDIS_PASSWORD=DPsPBEeQdmECVNDOzFGeZIbyEDeKYClT
BULL_REDIS_PASSWORD=0hbukRD765aX3ZADGawsaTR3mVPuRw1Y

# Port Memcached sur l'hôte (wise-eat-memcached, défaut 11211)
MEMCACHED_PORT=11211

MONGO_ROOT_USER=wise-eat-mongo
MONGO_ROOT_PASSWORD=
MONGO_REPLICA_SET=rs0

# Rétention Prometheus (compacte pour VPS 8 Go)
PROMETHEUS_RETENTION=15d

# RAM + swap par conteneur (memswap_limit = RAM + swap autorisé)
PROMETHEUS_MEM_LIMIT=512m
PROMETHEUS_MEMSWAP_LIMIT=768m
GRAFANA_MEM_LIMIT=256m
GRAFANA_MEMSWAP_LIMIT=384m
