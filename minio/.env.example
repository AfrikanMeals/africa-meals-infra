# MinIO — copier vers .env.minio sur le VPS (chmod 600)
MINIO_ROOT_USER=wise-eat-minio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=wise-eat
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1
# true = lecture publique anonyme sur le bucket (médias CDN-like)
MINIO_PUBLIC_READ=true

# Domaine public S3 (nginx + Let's Encrypt)
MINIO_STORAGE_DOMAIN=storage.wise-eat.com
MINIO_SERVER_URL=https://storage.wise-eat.com

# Console web MinIO (nginx + basic auth + TLS)
MINIO_CONSOLE_DOMAIN=cdn.wise-eat.com
MINIO_BROWSER_REDIRECT_URL=https://cdn.wise-eat.com
MINIO_CONSOLE_BASIC_AUTH_USER=minio-console
MINIO_CONSOLE_BASIC_AUTH_PASSWORD=

# Volume données (25 Go loop ext4 par défaut sur le VPS)
MINIO_DATA_DIR=/var/lib/wise-eat/minio
MINIO_STORAGE_GB=25
# Optionnel : bloc dédié au lieu du loop (ex. MINIO_DATA_DEVICE=/dev/sdb1)
# MINIO_DATA_DEVICE=

# Sauvegardes incrémentales (mc mirror — hors volume 25 Go)
MINIO_BACKUP_DIR=/var/backups/wise-eat-minio
MINIO_BACKUP_RETENTION_DAYS=30
MINIO_BACKUP_SNAPSHOT_WEEKDAY=7
MINIO_BACKUP_CRON=0 3 * * *
